# Build-time config for the live site. Both values are public by design: the
# embed key ships in the client bundle (that is what makes the chat callable
# from the browser), and the server bounds what it can spend via the layered
# per-conversation / per-IP / daily-budget caps. Vite inlines VITE_* vars at
# build time, so the GitHub Pages deploy picks these up with no secrets store.
VITE_SOAR_API=https://api.soar-crm.com
VITE_SOAR_INGEST_KEY=sik_MXUQ1F74Slzm4Rj0H3ZeKAzZ
